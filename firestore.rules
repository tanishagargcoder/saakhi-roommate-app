rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Signed-in users can browse profiles (needed for matching);
    // only the owner can create/edit/delete her own profile
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Room listings: browsable by members; only the owner can post/edit/remove hers
    match /listings/{listingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
    }

    // Safety reports: members can file them; nobody can read them from the client
    match /reports/{reportId} {
      allow create: if request.auth != null
        && request.resource.data.reporterId == request.auth.uid;
    }

    // Chats are visible only to their two participants
    match /chats/{chatId} {
      allow read, update: if request.auth != null
        && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participants;

      match /messages/{messageId} {
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && request.resource.data.from == request.auth.uid;
      }
    }
  }
}
